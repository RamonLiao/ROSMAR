{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@mysten/sui/keypairs/ed25519$": "<rootDir>/__mocks__/@mysten/sui/keypairs/ed25519.ts",
    "^@mysten/sui/jsonRpc$": "<rootDir>/__mocks__/@mysten/sui/jsonRpc.ts",
    "^@mysten/sui/transactions$": "<rootDir>/__mocks__/@mysten/sui/transactions.ts",
    "^@mysten/sui/utils$": "<rootDir>/__mocks__/@mysten/sui/utils.ts",
    "^@mysten/enoki$": "<rootDir>/__mocks__/@mysten/enoki.ts",
    "^src/(.*)$": "<rootDir>/../src/$1"
  }
}
